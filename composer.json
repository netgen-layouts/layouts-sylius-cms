{
    "name": "netgen/layouts-sylius-cms",
    "description": "Netgen Layouts, Sylius eCommerce & Sylius CMS plugin integration",
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Netgen",
            "homepage": "https://netgen.io"
        }
    ],
    "require": {
        "php": "^8.4",
        "sylius/cms-plugin": "^1.1",
        "netgen/layouts-sylius": "~2.0.0"
    },
    "require-dev": {
        "netgen/layouts-coding-standard": "^3.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "*": false
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit -c phpunit.xml --colors=always",
        "coverage": "@php -dzend_extension=xdebug.so -dxdebug.mode=coverage vendor/bin/phpunit -c phpunit.xml --coverage-html=coverage --colors=always",
        "phpstan": "@php vendor/bin/phpstan analyse -c phpstan.neon --ansi",
        "phpstan-tests": "@php vendor/bin/phpstan analyse -c phpstan.tests.neon --ansi"
    },
    "autoload": {
        "psr-4": {
            "Netgen\\Layouts\\Sylius\\Cms\\": "lib/",
            "Netgen\\Bundle\\LayoutsSyliusCmsBundle\\": "bundle/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Netgen\\Layouts\\Sylius\\Cms\\Tests\\": "tests/lib/",
            "Netgen\\Bundle\\LayoutsSyliusCmsBundle\\Tests\\": "tests/bundle/",
            "Netgen\\Layouts\\Tests\\": "vendor/netgen/layouts-core/tests/lib/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-master": "2.0.x-dev"
        }
    }
}
