{% set page = item.object %}

<div class="item sylius-cms-page">
    <a href="{{ path('sylius_cms_shop_page_show', { 'slug' : page.slug }) }}">

        <div class="content">

            {% if page.image %}
                <img class="ui left floated image" src="{{ page.image.path|imagine_filter(filter|default('sylius_small')) }}" alt="{{ item.name }}" />
            {% endif %}

            <h3>{{ page.name }}</h3>
            <p>
                {{ page.content|striptags|length > 200 ? page.content|striptags|slice(0, 200) ~ '...' : page.content|striptags }}
            </p>
        </div>
    </a>
</div>
