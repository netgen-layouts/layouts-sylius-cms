{% extends '@nglayouts/block/block.html.twig' %}

{% block content %}
    {% set field_identifier = block.parameter('field_identifier').value %}
    {% set html_element =  block.parameter('html_element').value %}
    {% set field = block.dynamicParameter('field') %}

    {% block sylius_cms_entity_field %}
        {% if field is not empty %}
            {% if field.type == enum('Netgen\\Layouts\\Sylius\\Cms\\Block\\BlockDefinition\\Handler\\EntityFieldType').DateTime %}
                <{{ html_element }} class="field field-{{ field.type.value }} field-{{ field_identifier }}">
                    {{ field.value|date(block.parameter('datetime_format').value)  }}
                </{{ html_element }}>
            {% else %}
                {{ 'sylius_cms.field_not_compatible'|trans({ '%field_identifier%': field_identifier }, 'sylius_cms') }}
            {% endif %}
        {%  endif %}
    {% endblock %}
{% endblock %}
